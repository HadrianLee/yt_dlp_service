<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="hhlhh.scene.ExitDialogScene">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16" />
    </padding>
    <children>
        <VBox spacing="16" prefWidth="420">
            <styleClass>
                <String fx:value="content-panel" />
                <String fx:value="dialog-panel" />
            </styleClass>
            <children>
                <Label fx:id="titleLabel" styleClass="page-title" />
                <Label fx:id="messageLabel" wrapText="true" />
                <HBox spacing="10" style="-fx-alignment: center-right;">
                    <children>
                        <Button fx:id="cancelButton" text="Keep downloading" />
                        <Button fx:id="exitButton" text="Exit" styleClass="danger-action" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>
