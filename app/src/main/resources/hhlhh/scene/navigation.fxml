<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="root"
      xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="hhlhh.scene.NavigationScene"
      spacing="8"
      styleClass="navigation-drawer">
    <children>
        <Label text="Menu" styleClass="section-title" />
        <Button fx:id="downloaderButton" text="Downloader" maxWidth="Infinity" styleClass="nav-button" />
        <Button fx:id="settingsButton" text="Settings" maxWidth="Infinity" styleClass="nav-button" />
    </children>
</VBox>
